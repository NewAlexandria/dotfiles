# Ghostty — colorful, attractive terminal config
# Copy to: ~/.config/ghostty/config (Linux) or
#          ~/Library/Application Support/com.mitchellh.ghostty/config (macOS)
# Reload: Ctrl+Shift+, (Linux) or Cmd+Shift+, (macOS)

# === Theme (pick one or use light/dark auto) ===
# Popular options: Catppuccin Mocha, Catppuccin Frappe, Tokyo Night, Dracula, One Dark
#theme = Catppuccin Mocha

# Auto-switch theme with system appearance (optional; comment out if you use single theme above):
 #theme = dark:Catppuccin Mocha,light:Catppuccin Latte

# === Font ===
font-family = "FiraCode Nerd Font Mono Retina"
font-size = 14
font-feature = calt,liga  # ligatures on (disable with -calt,-liga if you prefer)

# === Window & background ===
window-padding-x = 16
window-padding-y = 12
window-padding-balance = true
window-padding-color = background

# Slight transparency + blur (disable by setting background-opacity = 1 and background-blur = false)
background-opacity = 0.92
background-blur = true

# === Cursor ===
cursor-style = block
cursor-style-blink = true
cursor-opacity = 1.0

# === Colors & contrast ===
# Use bright colors for bold text (richer output for ls, grep, etc.)
bold-is-bright = true

# === Optional: list built-in themes ===
# Run: ghostty +list-themes


# theme = Tomorrow Night Burns
# configurator: https://ghostty.zerebos.com/app/import-export

# config-file = /Users/zak/.bash_profile
# command = source /Users/zak/.zshrc_local.sh

# Config generated by Ghostty Config

# theme = Github Dark High Contrast
theme = Hurtado
